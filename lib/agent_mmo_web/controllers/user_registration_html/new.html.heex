<div class="mx-auto max-w-sm mt-16 px-4">
  <h1 class="text-2xl font-bold text-center mb-8">Create an account</h1>

  <%= if @changeset.action do %>
    <div class="bg-red-900 border border-red-600 rounded p-3 mb-4 text-sm">
      Oops, something went wrong! Please check the errors below.
    </div>
  <% end %>

  <form action={~p"/users/register"} method="post" class="space-y-4">
    <input type="hidden" name="_csrf_token" value={Plug.CSRFProtection.get_csrf_token()} />

    <div>
      <label class="block text-sm font-medium mb-1">Email</label>
      <input type="email" name="user[email]" required
        value={Ecto.Changeset.get_field(@changeset, :email)}
        class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded text-white focus:outline-none focus:border-indigo-500" />
      <%= for error <- Keyword.get_values(@changeset.errors, :email) do %>
        <p class="text-red-400 text-xs mt-1"><%= translate_error(error) %></p>
      <% end %>
    </div>

    <div>
      <label class="block text-sm font-medium mb-1">Password</label>
      <input type="password" name="user[password]" required
        class="w-full px-3 py-2 bg-gray-800 border border-gray-700 rounded text-white focus:outline-none focus:border-indigo-500" />
      <%= for error <- Keyword.get_values(@changeset.errors, :password) do %>
        <p class="text-red-400 text-xs mt-1"><%= translate_error(error) %></p>
      <% end %>
    </div>

    <button type="submit"
      class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-4 rounded">
      Create account
    </button>
  </form>

  <p class="text-center text-sm text-gray-400 mt-4">
    Already have an account?
    <a href={~p"/users/log_in"} class="text-indigo-400 hover:underline">Log in</a>
  </p>
</div>
